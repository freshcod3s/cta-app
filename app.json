{
  "expo": {
    "name": "Congress Trade Alerts",
    "slug": "cta-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ctaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.congresstradealerts.cta",
      "supportsTablet": false,
      "associatedDomains": ["applinks:congresstradealerts.com"],
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Get alerts when Congress files new stock trades or hits compliance milestones."
      }
    },
    "android": {
      "package": "com.congresstradealerts.cta",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1220"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "congresstradealerts.com",
              "pathPrefix": "/trade"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0b1220"
        }
      ],
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9174d3a2-1b14-4c57-adaa-9fdadfff21a6"
      }
    },
    "owner": "freshcod3r"
  }
}
