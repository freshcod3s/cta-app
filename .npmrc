# Supply-chain cooldown. Refuses to install package versions published within
# the last N days, giving npm-registry / Socket / the OSS community time to
# catch and yank malicious releases (compromised maintainer accounts, typo-
# squats) before they land here.
#
# npm v11+ honors `min-release-age` (in days). Older npm and yarn ignore the
# key silently. pnpm uses `minimum-release-age` (in minutes) -- not set here
# because this repo is npm-only, but easy to add if a future migration lands.
min-release-age=3
